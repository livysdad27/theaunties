# theAunties Configuration
# Copy this to .env and fill in your values

# LLM API Keys
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Web Search API (for source discovery)
WEB_SEARCH_API_KEY=your-brave-search-api-key-here
WEB_SEARCH_PROVIDER=brave

# Google Drive
GOOGLE_DRIVE_CREDENTIALS_PATH=./credentials.json
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id-here
USER_EMAIL=your-email@example.com

# Scheduling
DEFAULT_SCHEDULE=0 6 * * *

# Logging
LOG_LEVEL=INFO

# Models (override defaults)
# LLM_DISCOVERY_MODEL=gemini-3.1-pro-preview
# LLM_SYNTHESIS_MODEL=claude-sonnet-4-6

# Development
USE_STUBS=true
